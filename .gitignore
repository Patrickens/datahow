# --- Provided challenge data (kept out of version control) -------------------
# The raw CSVs and spec are treated as confidential challenge material.
# See README.md for how to place them locally under data/.
data/

# --- Model artifacts / generated outputs -------------------------------------
# Ignore everything under artifacts/ (sweep scratch, parquet, predictions) EXCEPT
# the committed "best" models + metadata + notebook caches negated at the bottom
# of this file, so `make models`/`make figures` outputs don't need re-running.
artifacts/*
# Figures + notebook HTML are regenerated from the (confidential) data via
#   make figures   /   uv run marimo run exploration.py
figures/
*.parquet
*.npz
*.joblib
*.pkl
*.json.model

# --- Python -----------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# --- Tooling caches ----------------------------------------------------------
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/
__marimo__/
*.html

# --- Editor / OS -------------------------------------------------------------
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- Keep the challenge brief out of the repo too ----------------------------
*.pdf

# Local prompt scratch files (curated record lives in PROMPTS.md)
claude_*.txt

# --- Committed "best" artifacts (must come last to override the globs above) --
# Deployable models + their metadata + the notebook's caches are version-
# controlled so the service and the walkthrough work without retraining.
!artifacts/xgb_best.joblib
!artifacts/cde_best.eqx
!artifacts/xgb_best_metadata.json
!artifacts/cde_best_metadata.json
!artifacts/feature_importance.csv
!artifacts/cde_training_history.csv
# Sweep result tables (small; the notebook renders its top-config tables from them)
!artifacts/xgb_sweep_results.csv
!artifacts/cde_sweep_results.csv
